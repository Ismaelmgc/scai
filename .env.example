# ── Provider keys ───────────────────────────────────────────
# Pick ONE market-data provider and set its key:
SCAI_POLYGON_API_KEY=

# SEC EDGAR – put your email for polite-user-agent
SEC_EDGAR_USER_AGENT=your-email@example.com

# ── App settings ────────────────────────────────────────────
SCAI_ENV=development          # development | production
SCAI_DATA_DIR=./data
SCAI_LOG_LEVEL=INFO

# ── MLflow ──────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns

# ── Demo / Production toggle ───────────────────────────────
SCAI_MODE=demo                # demo | production
